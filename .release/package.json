    "conventional-changelog-conventionalcommits": "9.3.1",
    "semantic-release": "git+https://github.com/buehler/semantic-release.git#743218320b6f5a8041d3485da999a8dbb13f87d3",
    "semantic-release-net": "1.3.2"
  }
}
